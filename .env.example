# Primjer env varijabli za /api/send-order-emails (Vercel).
# Prave vrijednosti postavljaju se u Vercel dashboardu (Settings → Environment Variables),
# a za lokalni "vercel dev" kopiraj u .env i upiši stvarne vrijednosti.

# Gmail račun pošiljatelja
GMAIL_USER=mayamilicevic17@gmail.com

# 16-znamenkasti Gmail App Password (NE obična lozinka) — myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Adresa vlasnika/prodavača koja prima obavijest o narudžbi
OWNER_EMAIL=mayamilicevic17@gmail.com
